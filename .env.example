# QUICK_STYLE Configuration Template
# Copy this to .env and fill in your actual API keys (DO NOT commit .env to git)

ENV=development
SECRET_KEY=quick-style-dev-secret-key-12345

# MongoDB (use "mongodb" service name inside Docker network)
MONGODB_URI=mongodb://admin:quick_style_secret@mongodb:27017/quick_style_db?authSource=admin

# Redis (use "redis" service name inside Docker network)
REDIS_URL=redis://redis:6379/0

# Google Maps Platform (Directions API + Maps JS API enabled)
GOOGLE_MAPS_KEY=your_google_maps_key_here
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# AI Search (Tavily)
TAVILY_API_KEY=your_tavily_api_key_here

# PRIMARY LLM: Groq (Fast, free tier available)
# All AI agents (chat, registry, negotiation, intent) use Groq as primary
GROQ_API_KEY=your_groq_api_key_here

# FALLBACK LLM: Gemini 2.0 Flash
# Used when Groq fails, and for vision/audio tasks
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_API_KEY_FALLBACK=your_google_api_key_fallback_here

# Virtual Try-On & Model Image Generation: HuggingFace (IDM-VTON)
# Free serverless API via Gradio
HF_API_KEY=your_huggingface_api_key_here

# Google Cloud Vertex AI Credentials
GOOGLE_APPLICATION_CREDENTIALS=/app/google-credentials.json
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1

# WhatsApp Business API
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_id_here

# Celery (Async Tasks)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT Auth
JWT_SECRET=quick-style-jwt-secret-12345
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# CORS Origins
CORS_ORIGINS='["http://localhost:5173","http://localhost:80","http://localhost"]'
