{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://quick-style-bckend.onrender.com/api/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "https://quick-style-bckend.onrender.com/ws/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://quick-style-bckend.onrender.com/uploads/:path*"
    },
    {
      "source": "/generated/:path*",
      "destination": "https://quick-style-bckend.onrender.com/generated/:path*"
    },
    {
      "source": "/((?!api|ws|assets|stitch|ai-models|try-on|uploads|generated|favicon.ico).*)",
      "destination": "/index.html"
    }
  ]
}
