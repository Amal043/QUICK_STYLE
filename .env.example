# ─────────────────────────────────────────────────────────────────
# QUICK_STYLE Environment Variables — Copy to .env and fill values
# ─────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────
ENV=development
SECRET_KEY=your-super-secret-key-here-change-in-production

# ── MongoDB ───────────────────────────────────────────────────────
# Local Docker:  mongodb://admin:quick_style_secret@localhost:27017/quick_style_db?authSource=admin
# MongoDB Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/quick_style_db
MONGODB_URI=mongodb://admin:quick_style_secret@localhost:27017/quick_style_db?authSource=admin

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Google Maps Platform ──────────────────────────────────────────
# Enable: Maps JavaScript API, Places API, Directions API, Geocoding API
GOOGLE_MAPS_KEY=your-google-maps-api-key-here

# ── AI Search (Tavily) ────────────────────────────────────────────
# Sign up at https://tavily.com for a free API key
TAVILY_API_KEY=tvly-your-tavily-key-here

# ── WhatsApp Business API (Meta) ──────────────────────────────────
# For order status notifications
WHATSAPP_TOKEN=your-meta-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# ── Celery (Async Tasks) ──────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── JWT Auth ──────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── CORS Origins ──────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:80
